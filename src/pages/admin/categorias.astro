---
import AdminShell from '../../components/admin/AdminShell.astro';
import MainLayout from '../../layouts/MainLayout.astro';
import { loadCatalogData } from '../../lib/catalog.loader';

const { products, categories, subcategories } = await loadCatalogData();
---

<MainLayout title="Categorías | Stain The Canvas" bodyClass="admin-body">
  <AdminShell
    active="categories"
    products={products}
    categories={categories}
    subcategories={subcategories}
  />
</MainLayout>
