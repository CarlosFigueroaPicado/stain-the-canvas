---
interface Props {
  id?: string;
  name?: string;
  placeholder?: string;
  value?: string;
  ariaLabel?: string;
}

const {
  id = 'catalog-search',
  name = 'search',
  placeholder = 'Nombre del producto, Categoría, Sub Categoria',
  value = '',
  ariaLabel = 'Buscar productos'
} = Astro.props;
---

<label class="stc-search" for={id} aria-label={ariaLabel}>
  <svg class="stc-search__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
    <path d="m16.5 16.5 4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
  </svg>
  <input id={id} name={name} type="search" value={value} placeholder={placeholder} />
</label>
