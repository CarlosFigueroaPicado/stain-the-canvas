---
import type { Product } from '../../lib/catalog.repository';
import AdminTable from './AdminTable.astro';

interface Props {
  products: Product[];
}

const { products } = Astro.props;

function price(value: number) {
  return `C$${Number(value || 0).toFixed(2)}`;
}

function galleryPreview(product: Product) {
  const gallery = product.galleryUrls.length > 0 ? product.galleryUrls : product.imageUrl ? [product.imageUrl] : [];
  return gallery.slice(0, 4);
}
---

<section class="admin-section" aria-labelledby="products-title">
  <h2 id="products-title">Productos registrados</h2>
  <AdminTable headers={['Imagen', 'Nombre', 'Categoría', 'Subcategoría', 'Precio', 'Acciones']}>
    {products.map((product) => (
      <tr
        data-admin-product-row
        data-search={`${product.name} ${product.category} ${product.subcategory} ${product.description}`}
      >
        <td>
          <div class="admin-product-preview">
            <img class="admin-thumb" src={product.imageUrl} alt={product.name} loading="lazy" />
            <div class="admin-product-preview__gallery" aria-label={`Vista previa de imágenes de ${product.name}`}>
              {galleryPreview(product).map((imageUrl, previewIndex) => (
                <img
                  class="admin-product-preview__thumb"
                  src={imageUrl}
                  alt={`${product.name} - imagen ${previewIndex + 1}`}
                  loading="lazy"
                />
              ))}
              {product.galleryUrls.length > 4 && (
                <span class="admin-product-preview__count">+{product.galleryUrls.length - 4}</span>
              )}
            </div>
          </div>
        </td>
        <td>
          <strong>{product.name}</strong>
          <span>{product.description.split('.')[0]}</span>
        </td>
        <td>{product.category}</td>
        <td>{product.subcategory}</td>
        <td>{price(product.price)}</td>
        <td>
          <span class="admin-actions">
            <button
              class="admin-small-button"
              type="button"
              data-admin-modal="productModal"
              data-admin-product-mode="edit"
              data-product-id={product.id}
              data-product-name={product.name}
              data-product-category={product.category}
              data-product-subcategory-id={product.subcategoryId || ''}
              data-product-description={product.description}
              data-product-price={String(product.price)}
              data-product-image-url={product.imageUrl}
              data-product-gallery-urls={JSON.stringify(product.galleryUrls)}
              data-product-featured={String(product.featured)}
              data-product-video-url={product.videoUrl || ''}
            >
              Editar
            </button>
            <button
              class="admin-small-button admin-small-button--danger"
              type="button"
              data-admin-product-delete
              data-product-id={product.id}
              data-product-name={product.name}
            >
              Eliminar
            </button>
          </span>
        </td>
      </tr>
    ))}
  </AdminTable>
</section>
