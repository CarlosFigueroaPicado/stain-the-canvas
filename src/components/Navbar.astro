---
import Button from './Button.astro';

interface Props {
  title?: string;
  adminHref?: string;
  showAdminButton?: boolean;
}

const {
  title = 'Catálogo Digital Stain The Canvas',
  adminHref = '/login',
  showAdminButton = true
} = Astro.props;
---

<header class="stc-navbar">
  <div class="stc-navbar__inner">
    <div class="stc-navbar__spacer" aria-hidden="true"></div>
    <a class="stc-navbar__brand" href="/">{title}</a>
    {showAdminButton ? (
      <Button href={adminHref} size="sm" class="stc-navbar__action">Panel Admin</Button>
    ) : (
      <div class="stc-navbar__spacer" aria-hidden="true"></div>
    )}
  </div>
</header>
