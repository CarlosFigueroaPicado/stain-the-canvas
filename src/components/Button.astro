---
interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'secondary' | 'ghost' | 'danger';
  size?: 'sm' | 'md';
  class?: string;
  ariaLabel?: string;
  [key: string]: unknown;
}

const {
  href,
  type = 'button',
  variant = 'primary',
  size = 'md',
  class: className = '',
  ariaLabel,
  ...attrs
} = Astro.props;

const classes = ['stc-button', `stc-button--${variant}`, `stc-button--${size}`, className].filter(Boolean).join(' ');
---

{href ? (
  <a class={classes} href={href} aria-label={ariaLabel} {...attrs}>
    <slot />
  </a>
) : (
  <button class={classes} type={type} aria-label={ariaLabel} {...attrs}>
    <slot />
  </button>
)}
