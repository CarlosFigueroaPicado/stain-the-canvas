---
import Button from './Button.astro';
import Input from './Input.astro';
---

<section class="login-panel" aria-labelledby="login-title">
  <form class="login-form" data-login-form>
    <h1 id="login-title">Inicia Sesion Para acceder</h1>

    <Input
      id="adminEmail"
      name="email"
      label="Ingrese su correo"
      type="email"
      placeholder="Email"
      autocomplete="email"
      required
    />

    <div class="login-password">
      <Input
        id="adminPassword"
        name="password"
        label="Ingrese su contraseña"
        type="password"
        placeholder="Password"
        autocomplete="current-password"
        required
      />
      <button class="login-password__toggle" type="button" data-password-toggle aria-label="Mostrar contraseña" aria-pressed="false">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M2.5 12s3.4-6 9.5-6 9.5 6 9.5 6-3.4 6-9.5 6-9.5-6-9.5-6Z" stroke="currentColor" stroke-width="1.8"></path>
          <circle cx="12" cy="12" r="2.5" stroke="currentColor" stroke-width="1.8"></circle>
        </svg>
      </button>
    </div>

    <p class="login-form__status" data-login-status aria-live="polite"></p>

    <div class="login-form__actions">
      <Button type="submit">Ingresar</Button>
      <Button href="/" variant="ghost">Cancelar</Button>
    </div>
  </form>
</section>
